{
  "name": "retentix",
  "version": "0.0.1",
  "description": "Deterministic Data Retention & GDPR Execution Engine",
  "private": true,
  "type": "module",
  "main": "index.ts",
  "bin": {
    "retentix": "./cli/index.ts",
    "retentix-vendor": "./vendor/cli.ts"
  },
  "scripts": {
    "dev": "node --experimental-strip-types index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "type-check": "tsc --noEmit",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "check": "biome check .",
    "check:fix": "biome check --write ."
  },
  "dependencies": {
    "pg": "^8.20.0",
    "tweetnacl": "^1.0.3",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@types/node": "^25.6.2",
    "@types/pg": "^8.16.0",
    "@vitest/coverage-v8": "^4.1.5",
    "@vitest/ui": "^4.1.5",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5"
  },
  "homepage": "https://github.com/yaghouti/Retentix#readme",
  "bugs": {
    "url": "https://github.com/yaghouti/Retentix/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yaghouti/Retentix.git"
  },
  "license": "UNLICENSED",
  "author": "Majid Yaghouti",
  "packageManager": "pnpm@10.26.2",
  "engines": {
    "node": ">=24.0.0"
  }
}
